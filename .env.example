# MatdaanHub Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# Fastapi Configuration
SECRET_KEY=get_your_secret_key
DEBUG=false
TESTING=false
PORT=8080
HOST=0.0.0.0

# Google Gemini API (required for AI chat)
# Get from: https://ai.google.dev/gemini-api/docs/api-key
GEMINI_API_KEY=get_your_api_key

# Google Cloud Translate (optional, set true to enable)
GOOGLE_TRANSLATE_ENABLED=false

# Google Cloud Project (required for Vertex AI and Firestore)
GOOGLE_CLOUD_PROJECT=get_your_project_id
VERTEX_LOCATION=us-central1
VERTEX_GROUNDING_ENABLED=false

# Firebase / Firestore (optional, set true to enable)
FIREBASE_ENABLED=false

# Rate Limiting
CHAT_REQUESTS_PER_MINUTE=20
TRANSLATE_REQUESTS_PER_MINUTE=30
GENERAL_REQUESTS_PER_MINUTE=60

# Logging
LOG_LEVEL=INFO

# Optional: Cloud Run specific
# When deployed to Cloud Run, these are set automatically
CLOUD_RUN_PROJECT_ID=get_your_project_id
CLOUD_RUN_REGION=us-central1
